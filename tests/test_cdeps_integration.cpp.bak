/**
 * @brief Test stream offset specifications (positive offset).
 *
 * **Validates: Requirement 1.11**
 * - CDEPS SHALL support stream offset specifications
 * - Positive offset SHALL shift data forward in time
 *
 * **Test Strategy:**
 * 1. Create streams file with positive offset (3600 seconds = 1 hour)
 * 2. Initialize CDEPS
 * 3. Advance clock and verify offset is applied
 * 4. Verify no errors occur with offset
 */
TEST_F(CDEPSIntegrationTest, StreamOffsetPositive) {
    if (aces_cdeps_init == nullptr || aces_cdeps_advance == nullptr) {
        GTEST_SKIP() << "CDEPS bridge not available";
    }

    // Create streams file with 1-hour positive offset
    CreateTestStreamsFile("test_streams_offset.txt", "linear", 3600);

    AcesCdepsConfig config = CdepsStreamsParser::ParseStreamsFile("test_streams_offset.txt");
    ASSERT_EQ(config.streams[0].offset, 3600);

    AcesDataIngestor ingestor;

    EXPECT_NO_FATAL_FAILURE({
        ingestor.InitializeCDEPS(gcomp_, clock_, exportState_, mesh_, config);
    });

    // Advance clock 2 timesteps
    for (int i = 0; i < 2; ++i) {
        EXPECT_NO_FATAL_FAILURE({ ingestor.AdvanceCDEPS(clock_); });

        int rc;
        ESMC_ClockAdvance(clock_, &rc);
        EXPECT_EQ(rc, ESMF_SUCCESS);
    }

    ingestor.FinalizeCDEPS();
}

/**
 * @brief Test stream offset specifications (negative offset).
 *
 * **Validates: Requirement 1.11**
 * - CDEPS SHALL support stream offset specifications
 * - Negative offset SHALL shift data backward in time
 *
 * **Test Strategy:**
 * 1. Create streams file with negative offset (-1800 seconds = -30 minutes)
 * 2. Initialize CDEPS
 * 3. Advance clock and verify offset is applied

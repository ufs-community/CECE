TEST_F(CDEPSIntegrationTest, StreamOffsetNegative) {
    if (aces_cdeps_init == nullptr || aces_cdeps_advance == nullptr) {
        GTEST_SKIP() << "CDEPS bridge not available";
    }

    // Create streams file with 30-minute negative offset
    CreateTestStreamsFile("test_streams_offset.txt", "linear", -1800);

    AcesCdepsConfig config = CdepsStreamsParser::ParseStreamsFile("test_streams_offset.txt");
    ASSERT_EQ(config.streams[0].offset, -1800);

    AcesDataIngestor ingestor;

    EXPECT_NO_FATAL_FAILURE({
        ingestor.InitializeCDEPS(gcomp_, clock_, exportState_, mesh_, config);
    });

    // Advance clock 2 timesteps
    for (int i = 0; i < 2; ++i) {
        EXPECT_NO_FATAL_FAILURE({ ingestor.AdvanceCDEPS(clock_); });

        int rc;
        ESMC_ClockAdvance(clock_, &rc);
        EXPECT_EQ(rc, ESMF_SUCCESS);
    }

    ingestor.FinalizeCDEPS();
}

/**
 * @brief Test multi-timestep execution without handle corruption.
 *
 * **Validates: Requirement 1.12**
 * - CDEPS SHALL execute multiple timesteps without handle corruption
 * - ESMF handles SHALL remain valid throughout execution
 * - No segmentation faults SHALL occur during multi-timestep runs
 *
 * **Test Strategy:**
 * 1. Initialize CDEPS with valid configuration
 * 2. Execute 10 timesteps (advance clock and CDEPS)
 * 3. Verify ESMF handles remain valid after each timestep
 * 4. Verify no memory corruption or segfaults occur
 */
TEST_F(CDEPSIntegrationTest, MultiTimestepExecutionNoCorruption) {
    if (aces_cdeps_init == nullptr || aces_cdeps_advance == nullptr) {
        GTEST_SKIP() << "CDEPS bridge not available";
    }

    CreateTestStreamsFile("test_streams_init.txt", "linear");

    AcesCdepsConfig config = CdepsStreamsParser::ParseStreamsFile("test_streams_init.txt");
    AcesDataIngestor ingestor;

    EXPECT_NO_FATAL_FAILURE({
        ingestor.InitializeCDEPS(gcomp_, clock_, exportState_, mesh_, config);
    });

    // Execute 10 timesteps
    const int num_timesteps = 10;
    for (int i = 0; i < num_timesteps; ++i) {
        // Advance CDEPS
        EXPECT_NO_FATAL_FAILURE({ ingestor.AdvanceCDEPS(clock_); })
            << "CDEPS advance failed at timestep " << i;

        // Verify clock handle is still valid by getting current simulation time
        int rc;
        ESMC_TimeInterval currSimTime;
        ESMC_I8 advanceCount;
        rc = ESMC_ClockGet(clock_, &currSimTime, &advanceCount);
        EXPECT_EQ(rc, ESMF_SUCCESS) << "Clock handle corrupted at timestep " << i;

        // Advance clock
        rc = ESMC_ClockAdvance(clock_);
        EXPECT_EQ(rc, ESMF_SUCCESS) << "Clock advance failed at timestep " << i;

        // Verify clock is still valid after advance
        rc = ESMC_ClockGet(clock_, &currSimTime, &advanceCount);
        EXPECT_EQ(rc, ESMF_SUCCESS) << "Clock handle corrupted after advance at timestep " << i;
    }

    // Verify GridComp handle is still valid (just check it's not null)
    EXPECT_NE(gcomp_.ptr, nullptr) << "GridComp handle corrupted after multi-timestep execution";

    ingestor.FinalizeCDEPS();
}

/**
 * @brief Test handle validation after each timestep.
 *
 * **Validates: Requirement 1.12**
 * - ESMF handles SHALL remain valid after each CDEPS operation
 * - No handle corruption SHALL occur during CDEPS advance
 *
 * **Test Strategy:**
 * 1. Initialize CDEPS
 * 2. After each timestep, validate all ESMF handles
 * 3. Verify handles can be used for ESMF operations
 * 4. Ensure no memory corruption indicators
 */
TEST_F(CDEPSIntegrationTest, HandleValidationAfterEachTimestep) {
    if (aces_cdeps_init == nullptr || aces_cdeps_advance == nullptr) {
        GTEST_SKIP() << "CDEPS bridge not available";
    }

    CreateTestStreamsFile("test_streams_init.txt", "linear");

    AcesCdepsConfig config = CdepsStreamsParser::ParseStreamsFile("test_streams_init.txt");
    AcesDataIngestor ingestor;

    EXPECT_NO_FATAL_FAILURE({
        ingestor.InitializeCDEPS(gcomp_, clock_, exportState_, mesh_, config);
    });

    // Execute 5 timesteps with thorough handle validation
    for (int i = 0; i < 5; ++i) {
        // Advance CDEPS
        EXPECT_NO_FATAL_FAILURE({ ingestor.AdvanceCDEPS(clock_); });

        // Validate Clock handle using ESMC_ClockGet
        int rc;
        ESMC_TimeInterval currSimTime;
        ESMC_I8 advanceCount;
        rc = ESMC_ClockGet(clock_, &currSimTime, &advanceCount);
        EXPECT_EQ(rc, ESMF_SUCCESS) << "Clock handle invalid at timestep " << i;

        // Validate GridComp handle (check pointer is not null)
        EXPECT_NE(gcomp_.ptr, nullptr) << "GridComp handle invalid at timestep " << i;

        // Validate State handles (check pointers are not null)
        EXPECT_NE(exportState_.ptr, nullptr) << "ExportState handle invalid at timestep " << i;
        EXPECT_NE(importState_.ptr, nullptr) << "ImportState handle invalid at timestep " << i;

        // Advance clock for next iteration
        rc = ESMC_ClockAdvance(clock_);
        EXPECT_EQ(rc, ESMF_SUCCESS);
    }

    ingestor.FinalizeCDEPS();
}

/**
 * @brief Test CDEPS with multiple streams.
 *
 * **Validates: Requirements 1.1, 1.2, 1.3**
 * - CDEPS SHALL support multiple streams simultaneously
 * - Each stream SHALL have independent configuration
 * - All streams SHALL be accessible without conflicts
 *
 * **Test Strategy:**
 * 1. Create configuration with 3 streams
 * 2. Each stream has different interpolation mode
 * 3. Initialize CDEPS
 * 4. Advance and verify no conflicts between streams
 */
TEST_F(CDEPSIntegrationTest, MultipleStreamsConfiguration) {
    if (aces_cdeps_init == nullptr) {
        GTEST_SKIP() << "CDEPS bridge not available";
    }

    // Create streams file with multiple streams
    std::ofstream file("test_streams_init.txt");
    file << "# Multiple streams test\n";
    file << "stream::emissions_anthro\n";
    file << "  file_paths = /data/anthro.nc\n";
    file << "  variables = CO:CO_anthro\n";
    file << "  taxmode = cycle\n";
    file << "  tintalgo = linear\n";
    file << "  yearFirst = 2020\n";
    file << "  yearLast = 2020\n";
    file << "  yearAlign = 2020\n";
    file << "::\n\n";
    file << "stream::emissions_biogenic\n";
    file << "  file_paths = /data/biogenic.nc\n";
    file << "  variables = ISOP:isoprene\n";
    file << "  taxmode = extend\n";
    file << "  tintalgo = nearest\n";
    file << "  yearFirst = 2020\n";
    file << "  yearLast = 2020\n";
    file << "  yearAlign = 2020\n";
    file << "::\n\n";
    file << "stream::emissions_biomass\n";
    file << "  file_paths = /data/biomass.nc\n";
    file << "  variables = BC:black_carbon\n";
    file << "  taxmode = limit\n";
    file << "  tintalgo = none\n";
    file << "  yearFirst = 2020\n";
    file << "  yearLast = 2020\n";
    file << "  yearAlign = 2020\n";
    file << "::\n";
    file.close();

    AcesCdepsConfig config = CdepsStreamsParser::ParseStreamsFile("test_streams_init.txt");
    ASSERT_EQ(config.streams.size(), 3);

    // Verify each stream has correct configuration
    EXPECT_EQ(config.streams[0].name, "emissions_anthro");
    EXPECT_EQ(config.streams[0].tintalgo, "linear");
    EXPECT_EQ(config.streams[1].name, "emissions_biogenic");
    EXPECT_EQ(config.streams[1].tintalgo, "nearest");
    EXPECT_EQ(config.streams[2].name, "emissions_biomass");
    EXPECT_EQ(config.streams[2].tintalgo, "none");

    AcesDataIngestor ingestor;
    EXPECT_NO_FATAL_FAILURE({
        ingestor.InitializeCDEPS(gcomp_, clock_, exportState_, mesh_, config);
    });

    ingestor.FinalizeCDEPS();
}

/**
 * @brief Test CDEPS finalization and cleanup.
 *
 * **Validates: Requirement 1.12**
 * - CDEPS SHALL finalize cleanly without memory leaks
 * - ESMF handles SHALL remain valid after finalization
 *
 * **Test Strategy:**
 * 1. Initialize CDEPS
 * 2. Execute a few timesteps
 * 3. Finalize CDEPS
 * 4. Verify ESMF handles are still valid
 * 5. Verify no segfaults during cleanup
 */
TEST_F(CDEPSIntegrationTest, FinalizationCleanup) {
    if (aces_cdeps_init == nullptr || aces_cdeps_finalize == nullptr) {
        GTEST_SKIP() << "CDEPS bridge not available";
    }

    CreateTestStreamsFile("test_streams_init.txt", "linear");

    AcesCdepsConfig config = CdepsStreamsParser::ParseStreamsFile("test_streams_init.txt");
    AcesDataIngestor ingestor;

    EXPECT_NO_FATAL_FAILURE({
        ingestor.InitializeCDEPS(gcomp_, clock_, exportState_, mesh_, config);
    });

    // Execute 3 timesteps
    for (int i = 0; i < 3; ++i) {
        ingestor.AdvanceCDEPS(clock_);
        int rc = ESMC_ClockAdvance(clock_);
        EXPECT_EQ(rc, ESMF_SUCCESS);
    }

    // Finalize CDEPS
    EXPECT_NO_FATAL_FAILURE({ ingestor.FinalizeCDEPS(); });

    // Verify ESMF handles are still valid after CDEPS finalization
    int rc;
    ESMC_TimeInterval currSimTime;
    ESMC_I8 advanceCount;
    rc = ESMC_ClockGet(clock_, &currSimTime, &advanceCount);
    EXPECT_EQ(rc, ESMF_SUCCESS) << "Clock handle corrupted after CDEPS finalization";

    // Verify GridComp handle (check pointer is not null)
    EXPECT_NE(gcomp_.ptr, nullptr) << "GridComp handle corrupted after CDEPS finalization";
}

/**
 * @brief Test CDEPS with zero offset.
 *
 * **Validates: Requirement 1.11**
 * - CDEPS SHALL support zero offset (default behavior)
 * - Zero offset SHALL not affect data retrieval
 *
 * **Test Strategy:**
 * 1. Create streams file with offset = 0
 * 2. Initialize and advance CDEPS
 * 3. Verify no errors with zero offset
 */
TEST_F(CDEPSIntegrationTest, StreamOffsetZero) {
    if (aces_cdeps_init == nullptr) {
        GTEST_SKIP() << "CDEPS bridge not available";
    }

    CreateTestStreamsFile("test_streams_offset.txt", "linear", 0);

    AcesCdepsConfig config = CdepsStreamsParser::ParseStreamsFile("test_streams_offset.txt");
    ASSERT_EQ(config.streams[0].offset, 0);

    AcesDataIngestor ingestor;
    EXPECT_NO_FATAL_FAILURE({
        ingestor.InitializeCDEPS(gcomp_, clock_, exportState_, mesh_, config);
    });

    ingestor.FinalizeCDEPS();
}

}  // namespace test
}  // namespace aces

int main(int argc, char** argv) {
    ::testing::InitGoogleTest(&argc, argv);
    return RUN_ALL_TESTS();
}

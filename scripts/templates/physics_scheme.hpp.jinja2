     * @param export_state Output emission fields to be computed or modified
     *
     * @note Device-to-host synchronization is handled automatically by ACES
     *       after all schemes complete
     */
    void Run(AcesImportState& import_state, AcesExportState& export_state) override;

    /**
     * @brief Finalize the physics scheme.
     *
     * This method is called once during the Finalize phase. Use it to:
     * - Release any allocated resources
     * - Flush any pending I/O operations
     * - Clean up temporary data structures
     *
     * @note BasePhysicsScheme provides a default no-op implementation
     */
    void Finalize() override;

   private:
    // ========================================================================

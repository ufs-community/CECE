# ACES Configuration Example
# This file demonstrates the hybrid ingestion model where data can come from
# both ESMF (live meteorological state) and CDEPS-inline (static inventories on disk).

# Fields used in 'species' definitions are looked up in a unified state.
# ACES doesn't care where the field came from (ESMF or CDEPS); it just uses them.
species:
  nox:
    # 1. Base anthropogenic emissions read from a NetCDF file via CDEPS-inline.
    # The name "base_anthropogenic_nox" must match one of the streams defined below.
    - field: "base_anthropogenic_nox"
      operation: "add"
      scale: 1.0
      category: "anthropogenic"
      hierarchy: 1
      # We can use meteorological fields to scale emissions
      scale_fields:
        - "temperature"

    # 2. Influence from a field provided by another ESMF component (e.g. Atmosphere).
    # This demonstrates hybrid access to live state data.
    - field: "nox_from_atmosphere"
      operation: "add"
      scale: 1.0
      category: "met_influence"
      hierarchy: 1

physics_schemes: []

# CDEPS-inline configuration for reading static inventories from disk.
# These streams are ingested and made available as fields for the species above.
cdeps_inline_config:
  streams:
    - name: "base_anthropogenic_nox"
      file: "data/inventories/nox_2024.nc"
      interpolation: "linear"

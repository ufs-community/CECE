# ACES Configuration Example
# This file demonstrates the hybrid ingestion model where data can come from
# both ESMF (live meteorological state) and CDEPS-inline (static inventories on disk).

# Fields used in 'species' definitions are dynamically resolved.
# ACES first checks if a field is provided by CDEPS-inline (see 'cdeps_inline_config').
# If not found in CDEPS, it attempts to pull the field from the ESMF ImportState.
species:
  nox:
    # 1. Base anthropogenic emissions read from a NetCDF file via CDEPS-inline.
    # The name "base_anthropogenic_nox" must match one of the streams defined below.
    - field: "base_anthropogenic_nox"
      operation: "add"
      scale: 1.0
      category: "anthropogenic"
      hierarchy: 1
      # We can use meteorological fields to scale emissions.
      # Future support for complex thresholds or step functions can be implemented
      # in the compute engine functors.
      scale_fields:
        - "temperature"

    # 2. Additional NOx source provided directly by another ESMF component.
    - field: "nox_from_atmosphere"
      operation: "add"
      scale: 1.0
      category: "met_influence"
      hierarchy: 1

# List of physics schemes to initialize and run.
# Schemes can register diagnostic variables that can then be enabled for output.
physics_schemes:
  - name: "native_example"
    language: "cpp"
    options:
      scaling_factor: 2.0

# Diagnostic variables to write to disk at the end of each timestep.
# These variables must be registered by a physics scheme or the core engine.
# ACES will synchronize these from device to host and write them to NetCDF.
diagnostics:
  - "native_example_diag"

# CDEPS-inline configuration for reading static inventories from disk.
# Field names listed here will be looked up from disk.
# Any other field names used in the 'species' section above (like 'temperature' or
# 'nox_from_atmosphere') will be automatically pulled from the ESMF ImportState.
cdeps_inline_config:
  streams:
    - name: "base_anthropogenic_nox"
      file: "data/inventories/nox_2024.nc"
      interpolation: "linear"

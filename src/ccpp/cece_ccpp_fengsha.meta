[ccpp-table-properties]
  name = cece_ccpp_fengsha
  type = scheme
  dependencies = cece_ccpp_state.F90

[ccpp-arg-table]
  name = cece_ccpp_fengsha_init
  type = scheme
[horizontal_loop_extent]
  standard_name = horizontal_loop_extent
  long_name = horizontal loop extent
  units = count
  dimensions = ()
  type = integer
  intent = in
[vertical_layer_dimension]
  standard_name = vertical_layer_dimension
  long_name = number of vertical layers
  units = count
  dimensions = ()
  type = integer
  intent = in
[cece_configuration_file_path]
  standard_name = cece_configuration_file_path
  long_name = path to CECE YAML configuration file
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = in
[errmsg]
  standard_name = ccpp_error_message
  long_name = error message for error handling in CCPP
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = out
[errflg]
  standard_name = ccpp_error_code
  long_name = error code for error handling in CCPP
  units = 1
  dimensions = ()
  type = integer
  intent = out

[ccpp-arg-table]
  name = cece_ccpp_fengsha_run
  type = scheme
[horizontal_loop_extent]
  standard_name = horizontal_loop_extent
  long_name = horizontal loop extent
  units = count
  dimensions = ()
  type = integer
  intent = in
[vertical_layer_dimension]
  standard_name = vertical_layer_dimension
  long_name = number of vertical layers
  units = count
  dimensions = ()
  type = integer
  intent = in
[friction_velocity]
  standard_name = surface_friction_velocity
  long_name = surface friction velocity
  units = m s-1
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[threshold_velocity]
  standard_name = threshold_friction_velocity
  long_name = threshold friction velocity
  units = m s-1
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[soil_moisture]
  standard_name = soil_moisture
  long_name = volumetric soil moisture
  units = m3 m-3
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[clay_fraction]
  standard_name = clay_fraction
  long_name = fractional clay content
  units = frac
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[sand_fraction]
  standard_name = sand_fraction
  long_name = fractional sand content
  units = frac
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[silt_fraction]
  standard_name = silt_fraction
  long_name = fractional silt content
  units = frac
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[erodibility]
  standard_name = surface_erodibility
  long_name = sediment supply map erodibility
  units = 1
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[drag_partition]
  standard_name = drag_partition_correction
  long_name = drag partition correction factor
  units = 1
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[air_density]
  standard_name = air_density
  long_name = surface air density
  units = kg m-3
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[lake_fraction]
  standard_name = lake_fraction
  long_name = lake fraction
  units = frac
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[snow_fraction]
  standard_name = snow_fraction
  long_name = snow cover fraction
  units = frac
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[land_mask]
  standard_name = land_mask
  long_name = land mask
  units = 1
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[soil_temperature]
  standard_name = soil_temperature
  long_name = soil temperature for frozen ground check
  units = K
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[fengsha_dust_emission_flux]
  standard_name = fengsha_dust_emission_flux
  long_name = FENGSHA size-resolved dust emission flux
  units = kg m-2 s-1
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = out
[errmsg]
  standard_name = ccpp_error_message
  long_name = error message for error handling in CCPP
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = out
[errflg]
  standard_name = ccpp_error_code
  long_name = error code for error handling in CCPP
  units = 1
  dimensions = ()
  type = integer
  intent = out


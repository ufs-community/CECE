[ccpp-table-properties]
  name = cece_ccpp_stacking
  type = scheme
  dependencies = cece_ccpp_state.F90

[ccpp-arg-table]
  name = cece_ccpp_stacking_init
  type = scheme
[horizontal_loop_extent]
  standard_name = horizontal_loop_extent
  long_name = horizontal loop extent
  units = count
  dimensions = ()
  type = integer
  intent = in
[vertical_layer_dimension]
  standard_name = vertical_layer_dimension
  long_name = number of vertical layers
  units = count
  dimensions = ()
  type = integer
  intent = in
[cece_configuration_file_path]
  standard_name = cece_configuration_file_path
  long_name = path to CECE YAML configuration file
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = in
[errmsg]
  standard_name = ccpp_error_message
  long_name = error message for error handling in CCPP
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = out
[errflg]
  standard_name = ccpp_error_code
  long_name = error code for error handling in CCPP
  units = 1
  dimensions = ()
  type = integer
  intent = out

[ccpp-arg-table]
  name = cece_ccpp_stacking_run
  type = scheme
[horizontal_loop_extent]
  standard_name = horizontal_loop_extent
  long_name = horizontal loop extent
  units = count
  dimensions = ()
  type = integer
  intent = in
[vertical_layer_dimension]
  standard_name = vertical_layer_dimension
  long_name = number of vertical layers
  units = count
  dimensions = ()
  type = integer
  intent = in
[current_hour]
  standard_name = current_hour_of_day
  long_name = current hour of the day
  units = 1
  dimensions = ()
  type = integer
  intent = in
[current_day_of_week]
  standard_name = current_day_of_week
  long_name = current day of the week
  units = 1
  dimensions = ()
  type = integer
  intent = in
[errmsg]
  standard_name = ccpp_error_message
  long_name = error message for error handling in CCPP
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = out
[errflg]
  standard_name = ccpp_error_code
  long_name = error code for error handling in CCPP
  units = 1
  dimensions = ()
  type = integer
  intent = out


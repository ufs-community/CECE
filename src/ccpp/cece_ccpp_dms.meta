[ccpp-table-properties]
  name = cece_ccpp_dms
  type = scheme
  dependencies = cece_ccpp_state.F90

[ccpp-arg-table]
  name = cece_dms_init
  type = scheme
[horizontal_loop_extent]
  standard_name = horizontal_loop_extent
  long_name = horizontal loop extent
  units = count
  dimensions = ()
  type = integer
  intent = in
[vertical_layer_dimension]
  standard_name = vertical_layer_dimension
  long_name = number of vertical layers
  units = count
  dimensions = ()
  type = integer
  intent = in
[cece_configuration_file_path]
  standard_name = cece_configuration_file_path
  long_name = path to CECE YAML configuration file
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = in
[errmsg]
  standard_name = ccpp_error_message
  long_name = error message for error handling in CCPP
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = out
[errflg]
  standard_name = ccpp_error_code
  long_name = error code for error handling in CCPP
  units = 1
  dimensions = ()
  type = integer
  intent = out

[ccpp-arg-table]
  name = cece_dms_run
  type = scheme
[horizontal_loop_extent]
  standard_name = horizontal_loop_extent
  long_name = horizontal loop extent
  units = count
  dimensions = ()
  type = integer
  intent = in
[vertical_layer_dimension]
  standard_name = vertical_layer_dimension
  long_name = number of vertical layers
  units = count
  dimensions = ()
  type = integer
  intent = in
[surface_wind_speed]
  standard_name = wind_speed_at_10m
  long_name = wind speed at 10m
  units = m s-1
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[sea_surface_temperature]
  standard_name = sea_surface_skin_temperature
  long_name = sea surface temperature
  units = K
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = in
[dms_emission_flux]
  standard_name = dms_emission_flux
  long_name = DMS emission flux
  units = kg m-2 s-1
  dimensions = (horizontal_loop_extent, vertical_layer_dimension)
  type = real
  kind = kind_phys
  intent = out
[errmsg]
  standard_name = ccpp_error_message
  long_name = error message for error handling in CCPP
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = out
[errflg]
  standard_name = ccpp_error_code
  long_name = error code for error handling in CCPP
  units = 1
  dimensions = ()
  type = integer
  intent = out

[ccpp-arg-table]
  name = cece_dms_finalize
  type = scheme
[errmsg]
  standard_name = ccpp_error_message
  long_name = error message for error handling in CCPP
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = out
[errflg]
  standard_name = ccpp_error_code
  long_name = error code for error handling in CCPP
  units = 1
  dimensions = ()
  type = integer
  intent = out

[ccpp-arg-table]
  name = cece_dms_timestep_init
  type = scheme
[errmsg]
  standard_name = ccpp_error_message
  long_name = error message for error handling in CCPP
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = out
[errflg]
  standard_name = ccpp_error_code
  long_name = error code for error handling in CCPP
  units = 1
  dimensions = ()
  type = integer
  intent = out

[ccpp-arg-table]
  name = cece_dms_timestep_finalize
  type = scheme
[errmsg]
  standard_name = ccpp_error_message
  long_name = error message for error handling in CCPP
  units = none
  dimensions = ()
  type = character
  kind = len=512
  intent = out
[errflg]
  standard_name = ccpp_error_code
  long_name = error code for error handling in CCPP
  units = 1
  dimensions = ()
  type = integer
  intent = out
